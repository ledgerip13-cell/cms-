// 视频CMS 数据模型 — 采集源 / 影片 / 播放线路
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 采集源（管理后台核心：管理这些源头）
model Source {
  id           Int             @id @default(autoincrement())
  name         String // 源名称，如 "如意资源网"
  apiUrl       String // 采集API地址（主用/兼容旧数据，实际请求优先用 apiUrls）
  apiUrls      String          @default("[]") // JSON数组：多个API入口(主备)，按序尝试failover，空则回退用apiUrl
  driver       String          @default("maccms") // 采集驱动: maccms(苹果CMS标准) / nbflix(iCloud系源站) / jinpai(金牌影院系)
  signKey      String          @default("") // jinpai 等需签名的源：接口签名密钥(前端改算法时后台可改，空=用驱动内置默认)
  archiveRes   Int             @default(720) // 本地转存下载清晰度上限: 0=最高清 / 1080 / 720 / 480（源级，默认720）
  autoArchive  Boolean         @default(false) // 方案A：该源采集入库的新片是否自动排队转存(最高清)到本地硬盘
  activeApiUrl String          @default("") // 最近一次采集实际生效的url(运维可见性)
  playDomains  String          @default("[]") // JSON数组：该源已入库播放地址域名统计，供后台快速展示/替换
  flag         String          @default("") // from标识，如 rym3u8（可为空，自动探测）
  proxyMode    String          @default("inherit") // 回源模式: inherit(跟随全局)/direct(直连源站)/key(仅代理key)/proxy(TS中转)
  priority     Int             @default(100) // 线路优先级，越小越靠前
  enabled      Boolean         @default(true) // 开关
  cleanOnly    Boolean         @default(false) // 仅展示已清洗线路；用于广告源过滤
  status       String          @default("unknown") // ok / fail / unknown（测活结果）
  lastError    String? // 最近错误
  lastSyncAt   DateTime? // 最近采集时间
  syncCount    Int             @default(0) // 累计入库线路数
  // 定时采集
  autoSync     Boolean         @default(false) // 是否纳入定时采集
  autoTypeId   String          @default("") // 自动采集限定的源内 type_id JSON数组(空=全部；父类由采集器展开子类)
  syncHours    Int             @default(24) // 增量小时窗口
  cronExpr     String          @default("0 * * * *") // 采集频率(默认每小时)
  cursor       String? // 增量游标(最近成功采集时间点)
  plays        Play[]
  typeMaps     SourceTypeMap[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
}

// 统一分类体系（本站标准分类）
model Category {
  id              Int             @id @default(autoincrement())
  name            String          @unique // 统一分类名，如 "日韩动漫"
  slug            String          @default("") // 英文标识
  icon            String          @default("") // 分类图标key，前端按白名单渲染
  sort            Int             @default(100) // 展示排序
  parentId        Int? // 支持二级分类
  enabled         Boolean         @default(true)
  displayMode     String          @default("public") // public / login / vip / level / hidden（vip_or_level 仅旧数据兼容）
  displayLevelIds String          @default("[]") @map("displayGroupIds") // JSON数组：可展示的VIP等级ID
  watchMode       String          @default("inherit") // inherit / login / vip / level（vip_or_level 仅旧数据兼容）
  watchLevelIds   String          @default("[]") @map("watchGroupIds") // JSON数组：可观看的VIP等级ID
  maps            SourceTypeMap[]
  createdAt       DateTime        @default(now())
}

// 源分类映射：各源 type_id → 本站统一 Category
model SourceTypeMap {
  id             Int       @id @default(autoincrement())
  source         Source    @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  sourceId       Int
  sourceTypeId   String // 源内 type_id
  sourceTypeName String    @default("") // 源内分类名(参考)
  category       Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  categoryId     Int? // 映射到的统一分类(null=未映射)

  @@unique([sourceId, sourceTypeId])
}

// 站点基础信息（单例 id=1）
model SiteConfig {
  id                 Int      @id @default(1)
  siteName           String   @default("") // 网站名称
  logo               String   @default("") // 图标/Logo（URL 或 data URI）
  description        String   @default("") // 网站描述
  keywords           String   @default("") // SEO 关键词
  footer             String   @default("") // 页脚文字
  announcement       String   @default("") // 公告(可选)
  theme              String   @default("{}") // 前台主题配置 JSON
  homeConfig         String   @default("{}") // 首页配置 JSON
  shortsConfig       String   @default("{}") // 刷短剧配置 JSON
  playConfig         String   @default("{}") // 播放策略配置 JSON
  pwaConfig          String   @default("{}") // PWA安装与更新配置 JSON
  allowRegister      Boolean  @default(true) // 是否开放前台用户注册
  registerInviteCode String   @default("") // 注册邀请码(留空=不需要)
  updatedAt          DateTime @updatedAt
}

// 元数据采集配置（单例 id=1）
model MetaConfig {
  id                Int      @id @default(1)
  intervalMs        Int      @default(2500) // 限速间隔(毫秒/条)
  batchLimit        Int      @default(50) // 每批处理数
  autoMatchScore    Int      @default(80) // 达到该分数且满足强证据时自动写入
  pendingMatchScore Int      @default(60) // 达到该分数但不够自动写入时进入待确认
  autoMatch         Boolean  @default(false) // 定时自动匹配
  cronExpr          String   @default("0 4 * * *") // 频率(默认每天凌晨4点)
  redoFailed        Boolean  @default(false) // 定时时是否一并重试失败的
  saveImages        Boolean  @default(false) // 元数据匹配时是否同时保存图片到本地
  providersConfig   String   @default("{}") // 匹配源配置 JSON：douban/tmdb 开关、排序、TMDB凭据
  updatedAt         DateTime @updatedAt
}

// 首页热门推荐算法配置（单例 id=1）
model HotConfig {
  id             Int      @id @default(1)
  typeNames      String   @default("[]") // JSON数组：限定大分类，空=全部启用分类
  searchTerms    String   @default("[]") // JSON数组：运营热搜词，优先展示在前台搜索
  sortMode       String   @default("hot") // hot/rating/recent/created/pinned
  timeWindowDays Int      @default(0) // 0=不限；否则按 updatedAt 限定最近N天
  minRating      Float    @default(0)
  minRatingCount Int      @default(0)
  limit          Int      @default(12)
  updatedAt      DateTime @updatedAt
}

// HLS 广告清洗全局配置（单例 id=1）
model HlsCleanConfig {
  id                   Int      @id @default(1)
  enabled              Boolean  @default(false) // 总开关：关闭时播放永远返回原始源
  autoOnCollect        Boolean  @default(false) // 采集完成后自动排队清洗该源
  autoQueueOnMiss      Boolean  @default(false) // 播放命中缺失时是否异步排队清洗
  requireCleanPlayback Boolean  @default(false) // 开启后缺少 clean 结果不回退原始源
  minConfidence        Int      @default(80) // 低于该置信度不用于播放
  defaultStrategy      String   @default("discontinuity_profile_v1") // 默认清洗策略
  workerConcurrency    Int      @default(3) // 单个清洗任务内并发 worker 数
  sourceConcurrency    Int      @default(1) // 同一采集源并发探测上限，防止打爆源站
  updatedAt            DateTime @updatedAt
}

// HLS 清洗策略覆盖：支持按源、分类、单线路覆盖开关/策略
model HlsCleanPolicy {
  id         Int      @id @default(autoincrement())
  targetKey  String   @unique // source:1 / category:动漫 / play:123
  scope      String // source / category / play
  targetId   String
  targetName String   @default("")
  mode       String   @default("inherit") // inherit / enabled / disabled / dry_run
  strategyId String   @default("") // 留空继承全局策略
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())

  @@index([scope])
  @@index([mode])
}

// HLS 清洗结果：一条播放线路的某一集，对应一个原始 m3u8 hash 和策略
model HlsCleanResult {
  id            Int      @id @default(autoincrement())
  vodId         Int
  play          Play     @relation(fields: [playId], references: [id], onDelete: Cascade)
  playId        Int
  sourceId      Int
  epIndex       Int      @default(0)
  epName        String   @default("")
  originUrl     String   @default("") // 入库/分享页原地址
  resolvedUrl   String   @default("") // 解析后的 m3u8
  sourceUrlHash String
  m3u8Hash      String
  strategyId    String
  status        String   @default("pending") // clean / no_ads / uncertain / failed / dry_run / disabled
  confidence    Int      @default(0)
  adRanges      String   @default("[]") // JSON: [{start,end,segments,confidence,reason}]
  evidence      String   @default("{}") // JSON: groups/profile/signals
  cleanM3u8     String   @default("")
  error         String   @default("")
  checkedAt     DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([playId, epIndex, sourceUrlHash, strategyId])
  @@index([vodId])
  @@index([sourceId])
  @@index([status])
  @@index([strategyId])
  @@index([playId, sourceUrlHash, status, checkedAt])
}

// HLS 源级广告时长指纹库（duration_pattern_fingerprint_v1 专用，自学习）
// 同一条广告在同一采集源内跨片复用，时长序列前缀恒定；
// 从“段名重复循环插入”铁证块学到指纹后入库，供单次插入广告块匹配。
model HlsAdFingerprint {
  id        Int      @id @default(autoincrement())
  sourceId  Int
  prefix    String // 时长序列前缀，如 "4.00,5.48,4.00,3.24"
  segCount  Int      @default(0) // 学到时样本块的段数（参考）
  seenCount Int      @default(1) // 被多少个铁证实例印证（越高越可信）
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([sourceId, prefix])
  @@index([sourceId])
}

// 后台用户
model User {
  id        Int       @id @default(autoincrement())
  username  String    @unique
  password  String // bcrypt hash
  role      String    @default("admin") // admin / editor
  enabled   Boolean   @default(true)
  lastLogin DateTime?
  lastLoginIp String  @default("")
  createdAt DateTime  @default(now())
}

// 前台用户（观众账号，和后台管理员隔离）
model WebUser {
  id            Int                  @id @default(autoincrement())
  username      String               @unique
  email         String?              @unique
  nickname      String               @default("")
  gender        String               @default("") // unknown / male / female / other（前台资料展示）
  password      String
  enabled       Boolean              @default(true)
  isVip         Boolean              @default(false) // legacy：旧VIP开关，仅用于迁移，不再作为权限来源
  vipExpireAt   DateTime?
  vipLevel      VipLevel?            @relation(fields: [vipLevelId], references: [id], onDelete: SetNull)
  vipLevelId    Int?
  favoriteTypes String               @default("[]") // JSON: ["动漫","电影"]
  lastLogin     DateTime?
  lastLoginIp   String               @default("")
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  follows       UserFollow[]
  histories     WatchHistory[]
  skipPreferences UserVodSkipPreference[]
  searchLogs    SearchLog[]
  legacyGroups  LegacyWebUserGroup[] // 旧用户分组，仅用于迁移兼容
  usedInvites   InviteCode[]

  @@index([vipLevelId])
}

model SearchLog {
  id           Int      @id @default(autoincrement())
  kw           String
  normalizedKw String   @default("")
  source       String   @default("web")
  resultCount  Int      @default(0)
  user         WebUser? @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId       Int?
  ip           String   @default("")
  userAgent    String   @default("")
  createdAt    DateTime @default(now())

  @@index([kw])
  @@index([normalizedKw])
  @@index([source])
  @@index([userId])
  @@index([createdAt])
}

model VipLevel {
  id          Int       @id @default(autoincrement())
  code        String    @unique
  name        String    @unique
  tagColor    String    @default("#ffc233")
  legacyBadge String    @default("member") @map("badge") // legacy：旧徽章标识，仅保留数据库兼容
  sort        Int       @default(100)
  isDefault   Boolean   @default(false)
  isVip       Boolean   @default(false)
  remark      String    @default("")
  enabled     Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  users       WebUser[]

  @@index([enabled])
  @@index([sort])
}

model LegacyMemberGroup {
  id        Int                  @id @default(autoincrement())
  name      String               @unique
  remark    String               @default("")
  enabled   Boolean              @default(true)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  members   LegacyWebUserGroup[]

  @@map("MemberGroup")
}

model LegacyWebUserGroup {
  id        Int               @id @default(autoincrement())
  user      WebUser           @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int
  group     LegacyMemberGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  groupId   Int
  createdAt DateTime          @default(now())

  @@unique([userId, groupId])
  @@index([groupId])
  @@map("WebUserGroup")
}

model InviteCode {
  id        Int       @id @default(autoincrement())
  code      String    @unique
  remark    String    @default("")
  enabled   Boolean   @default(true)
  maxUses   Int       @default(1)
  usedCount Int       @default(0)
  expiresAt DateTime?
  usedBy    WebUser?  @relation(fields: [usedById], references: [id], onDelete: SetNull)
  usedById  Int?
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([enabled])
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  actorId   Int?
  actor     String   @default("")
  action    String
  target    String   @default("")
  detail    String   @default("{}")
  ip        String   @default("")
  createdAt DateTime @default(now())

  @@index([action])
  @@index([createdAt])
}

model QcIssue {
  id          Int       @id @default(autoincrement())
  issueKey    String    @unique
  type        String
  severity    String    @default("medium")
  title       String
  targetType  String    @default("")
  targetId    Int?
  targetName  String    @default("")
  sourceId    Int?
  sourceName  String    @default("")
  status      String    @default("open") // open / claimed / handling / closed / reviewing
  assigneeId  Int?
  assignee    String    @default("")
  note        String    @default("")
  detail      String    @default("{}")
  firstSeenAt DateTime  @default(now())
  lastSeenAt  DateTime  @default(now())
  handledAt   DateTime?
  closedAt    DateTime?
  reviewedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([type])
  @@index([status])
  @@index([severity])
  @@index([targetType, targetId])
  @@index([sourceId])
  @@index([lastSeenAt])
}

model AccessAudit {
  id        Int      @id @default(autoincrement())
  userId    Int?
  vodId     Int?
  action    String
  allowed   Boolean  @default(false)
  reason    String   @default("")
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([vodId])
  @@index([createdAt])
}

model IpLocationCache {
  id        Int      @id @default(autoincrement())
  ip        String   @unique
  country   String   @default("")
  region    String   @default("")
  city      String   @default("")
  isp       String   @default("")
  org       String   @default("")
  asn       String   @default("")
  source    String   @default("")
  raw       String   @default("{}")
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model PlaybackErrorLog {
  id         Int      @id @default(autoincrement())
  vodId      Int?
  vodName    String   @default("")
  playId     Int?
  lineName   String   @default("")
  sourceName String   @default("")
  epIndex    Int?
  epName     String   @default("")
  url        String   @default("")
  rule       String   @default("")
  proxyMode  String   @default("")
  cleanId    Int?
  fallbackUrl String  @default("")
  hlsErrorData String @default("{}")
  ipType     String   @default("")
  page       String   @default("")
  message    String   @default("")
  detail     String   @default("{}")
  ip         String   @default("")
  country    String   @default("")
  region     String   @default("")
  city       String   @default("")
  isp        String   @default("")
  userAgent  String   @default("")
  createdAt  DateTime @default(now())

  @@index([vodId])
  @@index([playId])
  @@index([sourceName])
  @@index([ipType])
  @@index([ip])
  @@index([createdAt])
}

model LoginLog {
  id        Int      @id @default(autoincrement())
  userType  String   @default("web") // admin / web
  userId    Int?
  username  String   @default("")
  success   Boolean  @default(false)
  message   String   @default("")
  ip        String   @default("")
  country   String   @default("")
  region    String   @default("")
  city      String   @default("")
  isp       String   @default("")
  userAgent String   @default("")
  createdAt DateTime @default(now())

  @@index([userType])
  @@index([userId])
  @@index([ip])
  @@index([success])
  @@index([createdAt])
}

model RequestAccessLog {
  id        Int      @id @default(autoincrement())
  userType  String   @default("") // admin / web / guest
  userId    Int?
  method    String
  path      String
  status    Int      @default(0)
  ms        Int      @default(0)
  ip        String   @default("")
  country   String   @default("")
  region    String   @default("")
  city      String   @default("")
  isp       String   @default("")
  userAgent String   @default("")
  referer   String   @default("")
  createdAt DateTime @default(now())

  @@index([path])
  @@index([status])
  @@index([ip])
  @@index([userType])
  @@index([createdAt])
}

// 影片（去重后唯一）
model Vod {
  id                       Int            @id @default(autoincrement())
  name                     String // 片名
  fingerprint              String         @unique // 去重指纹：normalize(name)|year
  year                     String         @default("")
  typeName                 String         @default("") // 统一大类名（电影/电视剧/…）
  subType                  String         @default("") // 原始小类/标签（剧情片/恐怖片/…）供大类下钻
  pic                      String         @default("") // 封面
  localPic                 String         @default("") // 本地化封面备用图，远程图失败时使用
  actor                    String         @default("")
  director                 String         @default("")
  area                     String         @default("")
  lang                     String         @default("")
  remarks                  String         @default("") // 更新至X集
  blurb                    String         @default("") // 简介
  heroPic                  String         @default("") // 首页/详情横版推荐图(优先级高于海报)
  status                   String         @default("online") // online / offline（下架）
  pinned                   Boolean        @default(false) // 置顶
  // 元数据（落库持久化，前端读库不实时抓）
  doubanId                 String? // 旧豆瓣条目id兼容字段
  metaSource               String         @default("") // 实际命中的元数据源：douban / tmdb
  metaSourceId             String         @default("") // 实际命中的源内ID
  rating                   Float? // 元数据评分
  ratingCount              Int            @default(0) // 评分人数
  popularity               Float? // TMDB 热度值(popularity)
  heatScore                Int            @default(0) // 全站统一热度值：第三方评分人数/TMDB popularity 归一后的最大值
  heatSource               String         @default("") // rating_count / tmdb_popularity
  officialPic              String         @default("") // 元数据高清封面
  officialIntro            String         @default("") // 元数据简介
  genres                   String         @default("") // 类型标签(逗号分隔)
  metaMatched              String         @default("none") // none/matched/manual/pending/failed/skip
  metaScore                Int            @default(0) // 元数据匹配置信分
  metaReason               String         @default("") // 匹配原因/候选快照(JSON)
  matchedTitle             String         @default("") // 实际命中的元数据标题
  matchedYear              String         @default("") // 实际命中的元数据年份
  metaAt                   DateTime? // 元数据抓取时间
  // 单片自动采集：按影片自身周期重拉现有片源详情，刷新剧集/状态
  autoCollectEnabled       Boolean        @default(false)
  autoCollectIntervalHours Int            @default(0)
  autoCollectMode          String         @default("days") // days / weekdays
  autoCollectIntervalDays  Int            @default(1)
  autoCollectWeekdays      String         @default("[]") // JSON: [1..7], 1=周一, 7=周日
  autoCollectNextAt        DateTime?
  autoCollectLastAt        DateTime?
  autoCollectMeta          Boolean        @default(true)
  autoCollectClean         Boolean        @default(false)
  // 本地转存(方案B手动 / 方案A自动)：把最高清片源下载切片存本地硬盘，播放优先走本地
  archiveStatus            String         @default("none") // none/pending/running/done/failed/off(手动关闭,不受源级自动影响)
  archiveRes               Int            @default(0) // 实际转存清晰度(如1080)
  archiveSize              Int            @default(0) // 已转存总大小(MB)
  archiveEps               Int            @default(0) // 已转存集数
  archivedAt               DateTime? // 最近转存完成时间
  plays                    Play[]
  aliases                  VodAlias[]
  people                   VodPerson[]
  images                   VodImage[]
  follows                  UserFollow[]
  histories                WatchHistory[]
  skipConfig               VodSkipConfig?
  skipPreferences          UserVodSkipPreference[]
  subTypes                 VodSubType[]   // 多分类标签(源站 vodClass 拆分)；subType 仅存主类型(首个)
  contentUpdatedAt         DateTime? // 内容/剧集真实更新时间；每日更新使用它，避免被元数据等后台维护任务污染
  updatedAt                DateTime       @updatedAt
  createdAt                DateTime       @default(now())

  @@index([name])
  @@index([typeName])
  @@index([subType])
  @@index([contentUpdatedAt])
  @@index([status, pinned, updatedAt, id])
  @@index([status, ratingCount, rating, updatedAt, id])
  @@index([status, rating, ratingCount, updatedAt, id])
  @@index([status, heatScore, rating, updatedAt, id])
  @@index([status, year, updatedAt, id])
  @@index([status, typeName, pinned, updatedAt, id])
  @@index([status, typeName, ratingCount, rating, updatedAt, id])
  @@index([status, typeName, rating, ratingCount, updatedAt, id])
  @@index([status, typeName, heatScore, rating, updatedAt, id])
  @@index([status, typeName, year, updatedAt, id])
  @@index([autoCollectEnabled, autoCollectNextAt])
  @@index([archiveStatus])
}

// 后台单片片头片尾配置：null 表示继承全局播放策略
model VodSkipConfig {
  vod          Vod      @relation(fields: [vodId], references: [id], onDelete: Cascade)
  vodId        Int      @id
  enabled      Boolean?
  introSeconds Int?
  outroSeconds Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// 手动合并后的去重别名：采集遇到旧指纹时继续归并到主影片
model VodAlias {
  id          Int      @id @default(autoincrement())
  fingerprint String   @unique
  vod         Vod      @relation(fields: [vodId], references: [id], onDelete: Cascade)
  vodId       Int
  note        String   @default("")
  createdAt   DateTime @default(now())

  @@index([vodId])
}

// 多分类标签：一部片可属多个子类型(源站 vodClass 如"剧情,悬疑,犯罪"拆分)
model VodSubType {
  id    Int    @id @default(autoincrement())
  vod   Vod    @relation(fields: [vodId], references: [id], onDelete: Cascade)
  vodId Int
  name  String // 单个子类型名(如 剧情/悬疑/犯罪)

  @@unique([vodId, name])
  @@index([name])
  @@index([vodId])
}

// 人物（演员/导演等，供搜索与作品聚合）
model Person {
  id        Int         @id @default(autoincrement())
  name      String
  doubanId  String      @default("")
  avatar    String      @default("")
  roles     VodPerson[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@unique([name])
  @@index([doubanId])
}

// 影片-人物关系
model VodPerson {
  id        Int      @id @default(autoincrement())
  vod       Vod      @relation(fields: [vodId], references: [id], onDelete: Cascade)
  vodId     Int
  person    Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  personId  Int
  role      String // actor / director
  character String   @default("")
  sort      Int      @default(0)
  createdAt DateTime @default(now())

  @@unique([vodId, personId, role])
  @@index([personId])
  @@index([vodId, role])
}

// 影片图片资产：poster/backdrop/still/avatar 等；不存梗图
model VodImage {
  id        Int      @id @default(autoincrement())
  vod       Vod      @relation(fields: [vodId], references: [id], onDelete: Cascade)
  vodId     Int
  url       String
  type      String   @default("still") // poster / backdrop / still
  source    String   @default("douban")
  width     Int      @default(0)
  height    Int      @default(0)
  score     Int      @default(0)
  isHero    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([vodId, url])
  @@index([vodId, type])
  @@index([isHero])
}

// 用户追剧
model UserFollow {
  id        Int      @id @default(autoincrement())
  user      WebUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int
  vod       Vod      @relation(fields: [vodId], references: [id], onDelete: Cascade)
  vodId     Int
  createdAt DateTime @default(now())

  @@unique([userId, vodId])
  @@index([userId])
  @@index([vodId])
}

// 用户观看历史（每部片保留最近一次进度）
model WatchHistory {
  id          Int      @id @default(autoincrement())
  user        WebUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      Int
  vod         Vod      @relation(fields: [vodId], references: [id], onDelete: Cascade)
  vodId       Int
  lineId      Int?
  epIndex     Int      @default(0)
  epName      String   @default("")
  progressSec Int      @default(0)
  durationSec Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, vodId, lineId])
  @@index([userId, updatedAt])
  @@index([userId, vodId, updatedAt])
  @@index([vodId])
}

// 用户本片片头片尾偏好：null 表示继承后台单片/全局配置
model UserVodSkipPreference {
  id           Int      @id @default(autoincrement())
  user         WebUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       Int
  vod          Vod      @relation(fields: [vodId], references: [id], onDelete: Cascade)
  vodId        Int
  enabled      Boolean?
  introSeconds Int?
  outroSeconds Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, vodId])
  @@index([vodId])
}

// 播放线路（一部片挂 N 条，来自不同源）
model Play {
  id             Int       @id @default(autoincrement())
  vod            Vod       @relation(fields: [vodId], references: [id], onDelete: Cascade)
  vodId          Int
  source         Source    @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  sourceId       Int
  sourceTypeId   String    @default("") // 线路来自源站哪个 type_id；前台只展示已映射 SourceTypeMap 的线路
  sourceTypeName String    @default("") // 源站分类名快照，辅助排查未映射线路
  sourceTypeMapped Boolean @default(false) // 采集时该源分类是否已人工映射；公共侧只展示 true 的线路
  flag           String // 播放器标识 from(如 rym3u8/wjm3u8)，同源同片可有多条不同flag线路
  sourceVodId    String // 该源内的原始 vod_id（增量更新用）
  episodes       String    @default("[]") // JSON: [{name,url}] 集数+m3u8
  epCount        Int       @default(0) // 集数
  syncedAt       DateTime  @default(now())
  // 探活与健康评分
  alive          Boolean   @default(true) // 首集探活结果
  checkMs        Int       @default(0) // 探活响应耗时(ms)
  lastCheck      DateTime? // 最近探活时间
  score          Int       @default(0) // 健康评分(越高越优先)
  playSuccessCount Int     @default(0) // 前台/解析成功计数
  playFailureCount Int     @default(0) // 播放失败计数
  avgResponseMs  Int       @default(0) // 解析/探测平均耗时
  lastSuccessAt  DateTime? // 最近成功
  lastFailureAt  DateTime? // 最近失败
  healthReason   String    @default("") // 健康评分原因
  playKind       String    @default("hls") // hls(直链) / iframe(分享页) / resolved(已解析)
  hasCleanResult Boolean   @default(false) // 反范式：是否已有 HLS 清洗成功结果

  cleanResults HlsCleanResult[] // Prisma 关联（跨表查询用）

  @@unique([sourceId, sourceVodId, flag]) // 同源同片同 flag 唯一，允许同源多 flag 并存
  @@index([vodId])
  @@index([sourceId, sourceVodId])
  @@index([sourceId, vodId])
  @@index([sourceId, sourceTypeId])
  @@index([score, lastSuccessAt])
}

// 采集任务（异步执行，前端点击后立即返回，去任务页看进度）
model Task {
  id          Int       @id @default(autoincrement())
  type        String    @default("collect") // collect 采集 / probe 探活 / meta 元数据 / hls_clean / archive(本地转存)
  sourceId    Int? // 关联源（采集任务）
  sourceName  String    @default("")
  mode        String    @default("incr") // incr / full
  status      String    @default("pending") // pending / running / paused / canceling / done / failed / canceled
  priority    Int       @default(100) // 数字越小越优先
  progress    Int       @default(0) // 0-100
  pageNow     Int       @default(0)
  pageTotal   Int       @default(0)
  added       Int       @default(0)
  updated     Int       @default(0)
  merged      Int       @default(0)
  message     String    @default("")
  params      String    @default("{}") // JSON 任务参数
  cursor      String? // JSON 断点续采游标(resume)
  resumeCount Int       @default(0) // 已自动续跑次数(防死循环)
  createdAt   DateTime  @default(now())
  startedAt   DateTime?
  finishedAt  DateTime?

  @@index([status])
  @@index([type])
  @@index([priority])
}

// 采集任务日志
model SyncLog {
  id        Int      @id @default(autoincrement())
  sourceId  Int
  mode      String // full / incr
  added     Int      @default(0)
  updated   Int      @default(0)
  merged    Int      @default(0) // 合并到已有影片数
  ok        Boolean  @default(true)
  message   String   @default("")
  ms        Int      @default(0)
  createdAt DateTime @default(now())
}
